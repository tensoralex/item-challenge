{
  "name": "item-challenge",
  "version": "1.0.0",
  "description": "Exam item management API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "dev:memory": "USE_DYNAMODB=false tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "synth": "cd infrastructure && npm install && npx cdk synth",
    "db:inspect": "tsx --env-file-if-exists=.env scripts/inspect_local_db.ts",
    "demo": "bash demo.sh",
    "lint": "eslint src scripts infrastructure",
    "lint:fix": "eslint src scripts infrastructure --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"infrastructure/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"infrastructure/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.9",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.48.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vite": "^6.4.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  }
}
