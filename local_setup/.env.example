# Environment variables for running the exam item management API
# against DynamoDB Local (see local_setup/LOCAL_SETUP.md).
#
# Copy to the repository root as .env, or export before starting the server:
#   cp local_setup/.env.example .env

# DynamoDB is the default backend; set false only for in-memory (pnpm dev:memory)
USE_DYNAMODB=true
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=ExamItems
AWS_REGION=us-east-1

# DynamoDB Local does not validate credentials; dummy values are sufficient.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
